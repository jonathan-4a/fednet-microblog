{
  "paths": {
    "/api/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Register a new local user",
        "operationId": "registerUser",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": {
                    "type": "string",
                    "default": "alice",
                    "description": "Unique local username used for login and ActivityPub address"
                  },
                  "password": {
                    "type": "string",
                    "default": "passw0rd!",
                    "description": "Raw password; stored hashed server-side"
                  },
                  "displayName": {
                    "type": "string",
                    "default": "Alice A.",
                    "description": "Optional display name shown in clients"
                  },
                  "summary": {
                    "type": "string",
                    "default": "Curious admin",
                    "description": "Optional user bio/summary"
                  },
                  "inviteToken": {
                    "type": "string",
                    "description": "Required when the server is configured for invite-only registration"
                  }
                },
                "required": ["username", "password"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthRegisterResponse"
                }
              }
            }
          },
          "400": { "description": "Missing or invalid data" },
          "409": { "description": "Username already exists" },
          "422": {
            "description": "Invite token missing or invalid when invite-only registration is enabled"
          },
          "500": { "description": "Unexpected server error" }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Authenticate and get a JWT",
        "operationId": "loginUser",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": {
                    "type": "string",
                    "default": "alice",
                    "description": "Existing username"
                  },
                  "password": {
                    "type": "string",
                    "default": "passw0rd!",
                    "description": "User password"
                  }
                },
                "required": ["username", "password"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful, JWT issued",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthLoginResponse"
                }
              }
            }
          },
          "400": { "description": "Missing credentials" },
          "401": { "description": "Invalid credentials or disabled account" },
          "500": { "description": "Unexpected server error" }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "tags": ["Auth"],
        "summary": "Logout and invalidate JWT token",
        "operationId": "logoutUser",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Logout successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "msg": {
                      "type": "string",
                      "example": "Logged out successfully"
                    }
                  }
                }
              }
            }
          },
          "401": { "description": "Unauthorized - Missing or invalid token" },
          "500": { "description": "Unexpected server error" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AuthRegisterResponse": {
        "type": "object",
        "properties": {
          "msg": {
            "type": "string",
            "description": "Human readable summary of the registration result",
            "example": "ok"
          }
        },
        "required": ["msg"]
      },
      "AuthLoginResponse": {
        "type": "object",
        "required": ["token", "user"],
        "properties": {
          "token": {
            "type": "string",
            "description": "JWT token for authenticated requests"
          },
          "user": {
            "type": "object",
            "required": [
              "username",
              "display_name",
              "summary",
              "is_admin",
              "is_active"
            ],
            "properties": {
              "username": { "type": "string" },
              "display_name": { "type": "string", "nullable": true },
              "summary": { "type": "string", "nullable": true },
              "is_admin": { "type": "integer", "enum": [0, 1] },
              "is_active": { "type": "integer", "enum": [0, 1] }
            }
          }
        }
      }
    }
  }
}

