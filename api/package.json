{
  "name": "microblog-api",
  "version": "0.0.1",
  "description": "FedNet Microblog API",
  "author": "Jonathan Ayalew",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "bun build src/server.ts --outdir dist --target bun",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "bun run src/server.ts",
    "start:dev": "bun --watch src/server.ts",
    "start:debug": "bun --inspect src/server.ts",
    "start:prod": "bun run dist/server.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "merge-docs": "node docs/mergeOpenapi.js",
    "dev:docs": "yarn merge-docs && yarn start:dev",
    "docker:up": "docker-compose -f docker/docker-compose.yml up",
    "docker:down": "docker-compose -f docker/docker-compose.yml down",
    "docker:build": "docker-compose -f docker/docker-compose.yml build",
    "docker:logs": "docker-compose -f docker/docker-compose.yml logs -f"
  },
  "dependencies": {
    "@meck93/kysely-bun-sqlite": "^0.2.0",
    "hono": "^4.11.7",
    "jsonwebtoken": "^9.0.2",
    "kysely": "^0.28.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.7",
    "@typescript-eslint/eslint-plugin": "^7",
    "@typescript-eslint/parser": "^7",
    "bun-types": "^1.3.7",
    "eslint": "^8",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16.0.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}

